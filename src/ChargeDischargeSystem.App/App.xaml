<Application x:Class="ChargeDischargeSystem.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ChargeDischargeSystem.App"
             xmlns:conv="clr-namespace:ChargeDischargeSystem.App.Converters"
             >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>

            <!-- Win11 颜色定义 - 简洁扁平化 -->
            <SolidColorBrush x:Key="PrimaryColor" Color="#0078D4"/>
            <SolidColorBrush x:Key="PrimaryDarkColor" Color="#005A9E"/>
            <SolidColorBrush x:Key="AccentColor" Color="#0078D4"/>
            <SolidColorBrush x:Key="SuccessColor" Color="#107C10"/>
            <SolidColorBrush x:Key="WarningColor" Color="#FF8C00"/>
            <SolidColorBrush x:Key="ErrorColor" Color="#D13438"/>
            <SolidColorBrush x:Key="WhiteColor" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="BackgroundColor" Color="#F3F3F3"/>
            <SolidColorBrush x:Key="SurfaceColor" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextPrimaryColor" Color="#1A1A1A"/>
            <SolidColorBrush x:Key="TextSecondaryColor" Color="#5C5C5C"/>
            <SolidColorBrush x:Key="BorderColor" Color="#E5E5E5"/>
            <SolidColorBrush x:Key="DividerColor" Color="#EDEDED"/>
            <SolidColorBrush x:Key="NavBackground" Color="#2D2D2D"/>
            <SolidColorBrush x:Key="NavTextColor" Color="#A0A0A0"/>
            <SolidColorBrush x:Key="NavActiveBackground" Color="#0078D4"/>
            <SolidColorBrush x:Key="NavActiveTextColor" Color="#FFFFFF"/>

            <FontFamily x:Key="GlobalFont">Segoe UI</FontFamily>

            <!-- Window基础样式 -->
            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
                <Setter Property="Background" Value="{StaticResource BackgroundColor}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <Style TargetType="UserControl">
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
                <Setter Property="Background" Value="{StaticResource BackgroundColor}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            </Style>

            <!-- Win11 扁平按钮样式 -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
            </Style>

            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
            </Style>

            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource ErrorColor}"/>
                <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <Style x:Key="SuccessButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SuccessColor}"/>
                <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <!-- Win11 扁平文本框 -->
            <Style x:Key="MaterialTextBox" TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
            </Style>

            <!-- Win11 扁平密码框 -->
            <Style x:Key="MaterialPasswordBox" TargetType="PasswordBox">
                <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
            </Style>

            <!-- Win11 扁平下拉框 -->
            <Style x:Key="MaterialComboBox" TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
            </Style>

            <!-- 状态按钮 -->
            <Style x:Key="StatusButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
                <Setter Property="MinWidth" Value="60"/>
            </Style>

            <!-- 参数显示 -->
            <Style x:Key="ParameterBorder" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- Win11 扁平DataGrid -->
            <Style x:Key="MaterialDataGrid" TargetType="DataGrid">
                <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="RowHeight" Value="32"/>
                <Setter Property="ColumnHeaderHeight" Value="36"/>
                <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource DividerColor}"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
            </Style>

            <!-- Win11 扁平TabControl -->
            <Style x:Key="MaterialTabControl" TargetType="TabControl">
                <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin" Value="2"/>
            </Style>

            <Style x:Key="MaterialTabItem" TargetType="TabItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
            </Style>

            <!-- Win11 扁平CheckBox -->
            <Style x:Key="MaterialCheckBox" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
            </Style>

            <!-- 表单标签 -->
            <Style x:Key="FormLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Margin" Value="2,6,2,2"/>
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
            </Style>

            <!-- Win11 扁平卡片 -->
            <Style x:Key="CardBorder" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardBackground}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Margin" Value="4"/>
            </Style>

            <!-- Win11 扁平ProgressBar -->
            <Style x:Key="MaterialProgressBar" TargetType="ProgressBar">
                <Setter Property="Height" Value="4"/>
                <Setter Property="Background" Value="{StaticResource DividerColor}"/>
                <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Margin" Value="2"/>
            </Style>

            <!-- 滚动条样式 -->
            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="8"/>
                <Setter Property="Background" Value="Transparent"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>