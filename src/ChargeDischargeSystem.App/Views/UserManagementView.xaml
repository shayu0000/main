<UserControl x:Class="ChargeDischargeSystem.App.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BackgroundColor}">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SurfaceColor}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,6,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,10">
                    <Button Content="添加用户" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddUserCommand}" Padding="14,6"/>
                    <Button Content="刷新" Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshCommand}" Padding="14,6" Margin="8,0,0,0"/>
                </StackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding UserList}"
                          SelectedItem="{Binding SelectedUser}"
                          Style="{StaticResource MaterialDataGrid}"
                          Margin="8,0,8,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="用户名" Binding="{Binding Username}" Width="100"/>
                        <DataGridTextColumn Header="显示名称" Binding="{Binding DisplayName}" Width="120"/>
                        <DataGridTextColumn Header="邮箱" Binding="{Binding Email}" Width="150"/>
                        <DataGridTextColumn Header="电话" Binding="{Binding Phone}" Width="100"/>
                        <DataGridTextColumn Header="角色" Binding="{Binding RoleId}" Width="90"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="70"/>
                        <DataGridTemplateColumn Header="操作" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="编辑" Padding="6,3" FontSize="12" Margin="2"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        <Button Content="删除" Padding="6,3" FontSize="12" Margin="2"
                                                Style="{StaticResource DangerButton}"
                                                Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource SurfaceColor}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                Margin="6,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <TextBlock Text="{Binding EditTitle}" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryColor}" Margin="0,0,0,12"/>

                    <TextBlock Text="用户名" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding EditUsername, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialTextBox}"/>

                    <TextBlock Text="密码" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding EditPassword, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialTextBox}"/>

                    <TextBlock Text="显示名称" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding EditDisplayName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialTextBox}"/>

                    <TextBlock Text="邮箱" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialTextBox}"/>

                    <TextBlock Text="电话" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialTextBox}"/>

                    <TextBlock Text="角色" Style="{StaticResource FormLabel}"/>
                    <ComboBox ItemsSource="{Binding RoleList}"
                              SelectedValue="{Binding EditRoleId}"
                              SelectedValuePath="RoleId"
                              Style="{StaticResource MaterialComboBox}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RoleName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource ErrorColor}"
                               FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="取消" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelEditCommand}" Width="70" Height="32" Margin="0,0,6,0"/>
                        <Button Content="保存" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveUserCommand}" Width="70" Height="32"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>