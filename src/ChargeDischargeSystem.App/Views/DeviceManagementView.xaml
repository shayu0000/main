<UserControl x:Class="ChargeDischargeSystem.App.Views.DeviceManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BackgroundColor}">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SurfaceColor}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,6,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8">
                    <Button Content="添加设备" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddDeviceCommand}" Padding="14,6"/>
                </StackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice}"
                          Style="{StaticResource MaterialDataGrid}" Margin="6,0,6,6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="设备ID" Binding="{Binding DeviceId}" Width="100"/>
                        <DataGridTextColumn Header="设备名称" Binding="{Binding DeviceName}" Width="130"/>
                        <DataGridTextColumn Header="类型" Binding="{Binding DeviceType}" Width="80"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="70"/>
                        <DataGridTextColumn Header="功率" Binding="{Binding RatedPowerKw}" Width="80"/>
                        <DataGridTemplateColumn Header="操作" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="编辑" Padding="6,3" FontSize="12" Margin="2"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding DataContext.EditDeviceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        <Button Content="删除" Padding="6,3" FontSize="12" Margin="2"
                                                Style="{StaticResource DangerButton}"
                                                Command="{Binding DataContext.DeleteDeviceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource SurfaceColor}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                Margin="6,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                    <TextBlock Text="{Binding EditTitle}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryColor}" Margin="0,0,0,10"/>

                    <TextBlock Text="设备名称" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding FormDeviceName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialTextBox}"/>

                    <TextBlock Text="设备类型" Style="{StaticResource FormLabel}"/>
                    <ComboBox Text="{Binding FormDeviceType}"
                              Style="{StaticResource MaterialComboBox}"
                              ItemsSource="{Binding TypeOptions}"/>

                    <TextBlock Text="额定功率(kW)" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding FormRatedPowerKw, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialTextBox}"/>

                    <TextBlock Text="CAN地址" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding FormCanAddress, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialTextBox}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="保存" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveDeviceCommand}" Width="70" Height="32" Margin="0,0,6,0"/>
                        <Button Content="取消" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelEditCommand}" Width="70" Height="32"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>