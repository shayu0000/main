<UserControl x:Class="ChargeDischargeSystem.App.Views.FirmwareUpgradeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1160"
             Background="{StaticResource BackgroundColor}">

    <!-- ============================================================ -->
    <!-- 固件升级页面                                                 -->
    <!-- ============================================================ -->
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- 设备选择 + 固件文件                                         -->
        <!-- ============================================================ -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="目标设备:"
                           Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          Style="{StaticResource MaterialComboBox}"
                          ItemsSource="{Binding DeviceList}"
                          SelectedItem="{Binding SelectedDevice}"
                          DisplayMemberPath="DeviceName"/>

                <TextBlock Grid.Column="2" Text="固件文件:"
                           Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="3"
                         Text="{Binding FirmwareFilePath}"
                         IsReadOnly="True"
                         Style="{StaticResource MaterialTextBox}"/>
                <Button Grid.Column="4" Content="浏览"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding BrowseFirmwareCommand}"
                        Height="32" Margin="4"/>

                <TextBlock Grid.Column="5" Text="目标版本:"
                           Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="6"
                         Text="{Binding TargetVersion, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialTextBox}"/>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- 升级进度 + 状态步骤                                         -->
        <!-- ============================================================ -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 进度条 -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="升级进度:"
                               Foreground="{StaticResource TextSecondaryColor}"
                               FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Column="1"
                                 Value="{Binding ProgressPercent}"
                                 Maximum="100"
                                 Style="{StaticResource MaterialProgressBar}"
                                 Height="14"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding ProgressPercent, StringFormat={}{0:F0} %}"
                               Foreground="{StaticResource AccentColor}"
                               FontSize="14" FontWeight="Bold"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <!-- 当前步骤 -->
                <TextBlock Grid.Row="1"
                           Text="{Binding CurrentStep}"
                           Foreground="{StaticResource TextPrimaryColor}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <!-- 状态机步骤可视化 -->
                <ItemsControl Grid.Row="2">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <!-- IDLE -->
                    <Border Margin="2" Padding="4" CornerRadius="4"
                            Background="{StaticResource BackgroundColor}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="准备" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryColor}"/>
                            <TextBlock Text="{Binding StepIdle}" FontSize="9"/>
                        </StackPanel>
                    </Border>
                    <!-- CHECK_VERSION -->
                    <Border Margin="2" Padding="4" CornerRadius="4"
                            Background="{StaticResource BackgroundColor}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="检查版本" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryColor}"/>
                            <TextBlock Text="{Binding StepCheckVersion}" FontSize="9"/>
                        </StackPanel>
                    </Border>
                    <!-- ENTER_BOOTLOADER -->
                    <Border Margin="2" Padding="4" CornerRadius="4"
                            Background="{StaticResource BackgroundColor}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="进入Boot" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryColor}"/>
                            <TextBlock Text="{Binding StepEnterBootloader}" FontSize="9"/>
                        </StackPanel>
                    </Border>
                    <!-- ERASE_FLASH -->
                    <Border Margin="2" Padding="4" CornerRadius="4"
                            Background="{StaticResource BackgroundColor}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="擦除Flash" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryColor}"/>
                            <TextBlock Text="{Binding StepEraseFlash}" FontSize="9"/>
                        </StackPanel>
                    </Border>
                    <!-- TRANSFER_DATA -->
                    <Border Margin="2" Padding="4" CornerRadius="4"
                            Background="{StaticResource BackgroundColor}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="传输数据" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryColor}"/>
                            <TextBlock Text="{Binding StepTransferData}" FontSize="9"/>
                        </StackPanel>
                    </Border>
                    <!-- VERIFY_FW -->
                    <Border Margin="2" Padding="4" CornerRadius="4"
                            Background="{StaticResource BackgroundColor}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="校验固件" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryColor}"/>
                            <TextBlock Text="{Binding StepVerifyFw}" FontSize="9"/>
                        </StackPanel>
                    </Border>
                    <!-- REBOOT_DEVICE -->
                    <Border Margin="2" Padding="4" CornerRadius="4"
                            Background="{StaticResource BackgroundColor}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="重启设备" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryColor}"/>
                            <TextBlock Text="{Binding StepReboot}" FontSize="9"/>
                        </StackPanel>
                    </Border>
                    <!-- COMPLETED -->
                    <Border Margin="2" Padding="4" CornerRadius="4"
                            Background="{StaticResource BackgroundColor}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="完成" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryColor}"/>
                            <TextBlock Text="{Binding StepCompleted}" FontSize="9"/>
                        </StackPanel>
                    </Border>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- 操作按钮                                                    -->
        <!-- ============================================================ -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="开始升级" Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartUpgradeCommand}"/>
                <Button Content="取消升级" Style="{StaticResource DangerButton}"
                        Command="{Binding CancelUpgradeCommand}"/>
                <Button Content="检查版本" Style="{StaticResource SecondaryButton}"
                        Command="{Binding CheckVersionCommand}"/>
                <Button Content="回滚" Style="{StaticResource SecondaryButton}"
                        Command="{Binding RollbackCommand}"/>
            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- 升级任务列表                                                -->
        <!-- ============================================================ -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="升级任务列表" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryColor}" Margin="0,0,0,8"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding TaskList}"
                          Style="{StaticResource MaterialDataGrid}"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="任务ID" Binding="{Binding TaskId}" Width="120"/>
                        <DataGridTextColumn Header="设备ID" Binding="{Binding DeviceId}" Width="120"/>
                        <DataGridTextColumn Header="源版本" Binding="{Binding FromVersion}" Width="100"/>
                        <DataGridTextColumn Header="目标版本" Binding="{Binding ToVersion}" Width="100"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                        <DataGridTextColumn Header="进度(%)" Binding="{Binding ProgressPercent}" Width="80"/>
                        <DataGridTextColumn Header="固件文件" Binding="{Binding FirmwareFile}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
