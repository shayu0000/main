<Window x:Class="ChargeDischargeSystem.App.Views.RegisterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="用户注册"
        Height="580"
        Width="380"
        HorizontalContentAlignment="Center"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">
    <Grid Margin="24,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="82*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="用户注册" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left"
                   Foreground="{StaticResource TextPrimaryColor}" Margin="126,0,0,16" Grid.Column="1"/>

        <StackPanel Grid.Row="1" Margin="2,2,2,2" Grid.ColumnSpan="2">
            <TextBlock Text="用户名 *" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialTextBox}" Height="34"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="2,2,2,2" Grid.ColumnSpan="2">
            <TextBlock Text="密码 *" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
            <PasswordBox x:Name="PasswordBox" Style="{StaticResource MaterialPasswordBox}"
                         Height="34" PasswordChanged="PasswordBox_PasswordChanged"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="2,2,2,2" Grid.ColumnSpan="2">
            <TextBlock Text="重复密码 *" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
            <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource MaterialPasswordBox}"
                         Height="34" PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="2,2,2,2" Grid.ColumnSpan="2">
            <TextBlock Text="姓名" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
            <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialTextBox}" Height="34"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="2,2,2,2" Grid.ColumnSpan="2">
            <TextBlock Text="部门" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
            <TextBox Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialTextBox}" Height="34"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Margin="2,2,2,2" Grid.ColumnSpan="2">
            <TextBlock Text="联系方式" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialTextBox}" Height="34"/>
        </StackPanel>

        <TextBlock Grid.Row="7" Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource ErrorColor}"
                   FontSize="12" TextWrapping="Wrap" Margin="2,2,2,2" Grid.ColumnSpan="2"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Left" Margin="74,2,0,10" Grid.Column="1">
            <Button Content="取消" Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}" Width="80" Height="34" Margin="10,2,2,2"/>
            <Button Content="注册" Style="{StaticResource PrimaryButton}"
                    Command="{Binding RegisterCommand}" Width="80" Height="34"/>
        </StackPanel>
    </Grid>
</Window>