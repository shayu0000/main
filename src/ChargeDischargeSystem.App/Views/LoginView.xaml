<UserControl x:Class="ChargeDischargeSystem.App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundColor}">

    <Grid Margin="0,0,0,0" Height="Auto">
        <Border Background="{StaticResource SurfaceColor}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="40,32" Height="Auto">
            <StackPanel Width="320">
                <TextBlock Text="充放电系统" FontSize="22" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryColor}"
                           Margin="4,4,4,4"/>
              

                <TextBlock Text="用户名" Style="{StaticResource FormLabel}" HorizontalAlignment="Center" Margin="2,2,2,2"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialTextBox}"
                         Height="36" Margin="4,4,4,4"/>

                <TextBlock Text="密码" Style="{StaticResource FormLabel}" HorizontalAlignment="Center" Margin="2,2,2,2"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource MaterialPasswordBox}"
                             Height="36"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             Margin="4,4,4,4"/>

                <StackPanel Orientation="Horizontal" Margin="4,4,4,4" HorizontalAlignment="Center">
                    <CheckBox Content="记住用户名" IsChecked="{Binding RememberUsername}"
                              Style="{StaticResource MaterialCheckBox}" />
                    <CheckBox Content="记住密码" IsChecked="{Binding RememberPassword}"
                              Style="{StaticResource MaterialCheckBox}"/>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorColor}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                           Margin="4,4,4,4"
                           TextWrapping="Wrap" Width="312"/>

                <ProgressBar IsIndeterminate="True" Height="6"
                             Visibility="{Binding IsLoggingIn, Converter={StaticResource BoolToVisibility}}"
                             Style="{StaticResource MaterialProgressBar}"
                             Margin="4,4,4,4"/>

                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryColor}"
                           Margin="4,4,4,4"/>

                <Button Content="登录" Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}"
                        Height="38" Margin="4,4,4,4"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="注册" Style="{StaticResource SecondaryButton}"
                            Command="{Binding OpenRegisterDialogCommand}" Height="34" Margin="2,2,2,2"/>
                    <Button Grid.Column="1" Content="退出" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExitCommand}" Height="34" Margin="2,2,2,2"/>
                </Grid>

                <TextBlock Text="v1.0" FontSize="12"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryColor}"
                           Margin="2,2,2,2"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>