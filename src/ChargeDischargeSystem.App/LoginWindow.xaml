<!-- ============================================================ -->
<!-- MW级充放电上位机系统 - 登录窗口                               -->
<!-- 文件名: LoginWindow.xaml                                      -->
<!-- 说明: 登录窗口，无边框设计，居中显示                          -->
<!--       内嵌 LoginView 用户控件作为登录表单内容                 -->
<!-- ============================================================ -->
<Window x:Class="ChargeDischargeSystem.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ChargeDischargeSystem.App.Views"
        Title="MW级充放电上位机系统 - 登录"
        Width="500"
        Height="580"
        MinWidth="400"
        MinHeight="550"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <!-- ============================================================ -->
    <!-- 窗口内容布局                                                  -->
    <!-- 外层Border提供圆角边框和阴影效果，内层直接承载LoginView      -->
    <!-- ============================================================ -->
    <Border Background="{StaticResource BackgroundColor}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="12">

        <!-- 直接将 LoginView 用户控件嵌入为窗口内容 -->
        <views:LoginView x:Name="LoginViewControl"/>
    </Border>
</Window>
