<Window x:Class="ChargeDischargeSystem.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ChargeDischargeSystem.App.ViewModels"
        xmlns:views="clr-namespace:ChargeDischargeSystem.App.Views"
        mc:Ignorable="d"
        Background="{StaticResource BackgroundColor}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DeviceManagementViewModel}">
            <views:DeviceManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CalibrationViewModel}">
            <views:CalibrationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProtocolManagementViewModel}">
            <views:ProtocolManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BatteryProtocolViewModel}">
            <views:BatteryProtocolView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DataRecordViewModel}">
            <views:DataRecordView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FirmwareUpgradeViewModel}">
            <views:FirmwareUpgradeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FaultRecordViewModel}">
            <views:FaultRecordView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserManagementViewModel}">
            <views:UserManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportViewModel}">
            <views:ReportView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Navigation -->
        <Border Grid.Column="0" Background="{StaticResource NavBackground}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Height="48" BorderBrush="#3D3D3D" BorderThickness="0,0,0,1">
                    <TextBlock Text="充放电系统"
                               Foreground="{StaticResource WhiteColor}"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0"/>
                </Border>

                <Border Grid.Row="1" Padding="12,10" BorderBrush="#3D3D3D" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentUserName}"
                                   Foreground="{StaticResource WhiteColor}"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding CurrentUserRole}"
                                   Foreground="{StaticResource NavTextColor}"
                                   FontSize="11"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SidebarMenuItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding PageName}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Stretch"
                                        Cursor="Hand"
                                        Height="40"
                                        Padding="12,0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource NavActiveBackground}"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3D3D3D"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="{StaticResource NavTextColor}"
                                               FontSize="13"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="3"
                        Command="{Binding ExitCommand}"
                        Height="40"
                        Margin="4,4,4,4"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource ErrorColor}"
                        FontSize="12"
                        Content="退出系统"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Border Grid.Column="1" Background="{StaticResource BackgroundColor}">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>
    </Grid>
</Window>